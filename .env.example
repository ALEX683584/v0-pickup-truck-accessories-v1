# ──────────────────────────────────────────────
# Site Configuration
# ──────────────────────────────────────────────
# The canonical public URL of the site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.tobekin.com

# ──────────────────────────────────────────────
# Contact Form — Email Delivery
# ──────────────────────────────────────────────
# Option A: Resend (preferred)
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=

# Option B: SMTP fallback (used if RESEND_API_KEY is not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# The email address that receives contact form submissions
CONTACT_EMAIL=admin@tobekin.com
